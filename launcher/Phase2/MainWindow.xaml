<Window
    x:Class="OfficeAgent.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="OfficeAgent"
    Width="1280" Height="800"
    MinWidth="900" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Closing="OnWindowClosing">

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="OfficeAgent"/>
    </Window.TaskbarItemInfo>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- Title bar strip -->
            <RowDefinition Height="*"/>    <!-- WebView2 -->
        </Grid.RowDefinitions>

        <!-- Thin branded title bar -->
        <Border Grid.Row="0" Background="{StaticResource BrandDark}">
            <Grid>
                <TextBlock Text="OfficeAgent"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <!-- Tier badge -->
                <Border x:Name="TierBadge"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        CornerRadius="3"
                        Padding="6,2"
                        Background="{StaticResource BrandBlue}">
                    <TextBlock x:Name="TierLabel"
                               Text="Standard"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="11"
                               Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- WebView2: renders the Streamlit UI at http://127.0.0.1:8501 -->
        <wv2:WebView2
            x:Name="WebView"
            Grid.Row="1"
            Source="about:blank"/>

        <!-- Loading overlay — shown while Streamlit is initialising -->
        <Border x:Name="LoadingOverlay"
                Grid.Row="1"
                Background="{StaticResource BrandLight}"
                Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="読み込み中..."
                           FontFamily="{StaticResource UiFont}"
                           FontSize="15"
                           Foreground="#666666"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True"
                             Width="200" Height="4"
                             Margin="0,12,0,0"
                             Foreground="{StaticResource BrandBlue}"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>

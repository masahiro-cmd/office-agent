{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "XlsxPlan",
  "description": "Schema for Excel workbook generation plan",
  "type": "object",
  "required": ["workbook_title", "sheets"],
  "additionalProperties": false,
  "properties": {
    "workbook_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "sheets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "headers", "rows"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 31
          },
          "headers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": ["string", "number", "null", "boolean"] }
            }
          },
          "formulas": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "required": ["cell", "formula"],
              "additionalProperties": false,
              "properties": {
                "cell":    { "type": "string", "pattern": "^[A-Z]+[0-9]+$" },
                "formula": { "type": "string", "minLength": 1 }
              }
            }
          },
          "filters": {
            "type": ["boolean", "null"],
            "default": false
          },
          "freeze_pane": {
            "type": ["string", "null"],
            "pattern": "^[A-Z]+[0-9]+$",
            "description": "e.g. 'A2' to freeze the first row"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocxPlan",
  "description": "Schema for Word document generation plan",
  "type": "object",
  "required": ["title", "sections"],
  "additionalProperties": false,
  "properties": {
    "document_type": {
      "type": "string",
      "enum": ["ringi", "report", "manual", "general"],
      "default": "general"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "author":     { "type": "string" },
        "date":       { "type": "string" },
        "department": { "type": "string" },
        "version":    { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["heading"],
        "additionalProperties": false,
        "properties": {
          "heading":  { "type": "string" },
          "level":    { "type": "integer", "minimum": 1, "maximum": 9, "default": 1 },
          "content":  { "type": ["string", "null"], "default": "" },
          "bullets": {
            "type": ["array", "null"],
            "items": { "type": "string" }
          },
          "table": {
            "type": ["object", "null"],
            "required": ["headers", "rows"],
            "additionalProperties": false,
            "properties": {
              "headers": { "type": "array", "items": { "type": "string" } },
              "rows": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": ["string", "number", "null"] }
                }
              }
            }
          },
          "footnote": { "type": ["string", "null"] }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PptxPlan",
  "description": "Schema for PowerPoint presentation generation plan",
  "type": "object",
  "required": ["presentation_title", "slides"],
  "additionalProperties": false,
  "properties": {
    "presentation_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "template": {
      "type": ["string", "null"],
      "description": "'default' or a path to a .pptx template file",
      "default": "default"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_type", "title"],
        "additionalProperties": false,
        "properties": {
          "slide_type": {
            "type": "string",
            "enum": ["title", "content", "two_column", "blank"]
          },
          "title":   { "type": "string" },
          "bullets": {
            "type": ["array", "null"],
            "items": { "type": "string" }
          },
          "table": {
            "type": ["object", "null"],
            "required": ["headers", "rows"],
            "additionalProperties": false,
            "properties": {
              "headers": { "type": "array", "items": { "type": "string" } },
              "rows": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": ["string", "number", "null"] }
                }
              }
            }
          },
          "notes": { "type": ["string", "null"], "default": "" }
        }
      }
    }
  }
}
